<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify OTP - Student Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">
    <div class="min-h-screen flex items-center justify-center">
        <div class="bg-white p-8 rounded-lg shadow-md w-full max-w-md">
            <div class="text-center mb-8">
                <h2 class="text-3xl font-bold text-gray-800">Verify OTP</h2>
                <p class="text-gray-600 mt-2">Enter the 6-digit code sent to your email</p>
                <p class="text-sm text-gray-500 mt-1"><%= email %></p>
            </div>

            <% if (error) { %>
                <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                    <%= error %>
                </div>
            <% } %>

            <% if (success) { %>
                <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
                    <%= success %>
                </div>
            <% } %>

            <form action="/verify-otp" method="POST">
                <input type="hidden" name="email" value="<%= email %>">
                
                <div class="mb-6">
                    <label class="block text-gray-700 text-sm font-bold mb-2" for="otp">
                        OTP Code
                    </label>
                    <input type="text" 
                           id="otp"
                           name="otp" 
                           required
                           maxlength="6"
                           pattern="[0-9]{6}"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-blue-500 text-center text-2xl tracking-widest"
                           placeholder="000000">
                </div>

                <button type="submit" 
                        class="w-full bg-blue-500 text-white font-bold py-2 px-4 rounded-lg hover:bg-blue-600 transition duration-300">
                    Verify OTP
                </button>
            </form>

            <div class="mt-4 text-center">
                <a href="/forgot-password" class="text-blue-500 hover:text-blue-600 text-sm">Resend OTP</a>
            </div>
        </div>
    </div>
</body>
</html>