<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Student Registration | E&CE Department</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Inter','Segoe UI',sans-serif;
        }
        body{
            background:linear-gradient(135deg,#f0f9ff 0%,#e0f2fe 50%,#fdf4ff 100%);
            padding: 40px 0;
        }
        .register-container{
            max-width: 800px;
            margin: auto;
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }
        h2{
            text-align: center;
            background: linear-gradient(90deg, #0d6efd, #6f42c1);
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 20px;
        }
        .form-label{
            font-weight: 600;
        }
        .btn-register{
            background: linear-gradient(135deg, #0d6efd, #6f42c1);
            border: none;
            padding: 12px;
            font-weight: bold;
            color: white;
            width: 100%;
            border-radius: 10px;
        }
        .login-link{
            text-align: center;
            margin-top: 15px;
        }
    </style>
</head>
<body>
<div class="register-container">
    <h2><i class="fas fa-user-plus me-2"></i> Student Registration</h2>

    <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <form action="/register" method="POST">
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Full Name *</label>
                <input type="text" name="name" class="form-control" value="<%= formData.name || '' %>" required>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Department *</label>
                <input type="text" name="department" class="form-control" value="<%= formData.department || '' %>" required>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Year *</label>
                <select name="year" class="form-control" required>
                    <option value="">Select Year</option>
                    <option value="FE" <%= formData.year === 'FE' ? 'selected' : '' %>>FE</option>
                    <option value="SE" <%= formData.year === 'SE' ? 'selected' : '' %>>SE</option>
                    <option value="TE" <%= formData.year === 'TE' ? 'selected' : '' %>>TE</option>
                    <option value="BE" <%= formData.year === 'BE' ? 'selected' : '' %>>BE</option>
                </select>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Email *</label>
                <input type="email" name="email" class="form-control" value="<%= formData.email || '' %>" required>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Mobile No *</label>
                <input type="text" name="mobile" class="form-control" value="<%= formData.mobile || '' %>" required>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">PRN No *</label>
                <input type="text" name="prn" class="form-control" value="<%= formData.prn || '' %>" required>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Parents Name</label>
                <input type="text" name="parents_name" class="form-control" value="<%= formData.parents_name || '' %>">
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Parents Mobile</label>
                <input type="text" name="parents_mobile" class="form-control" value="<%= formData.parents_mobile || '' %>">
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Password *</label>
                <input type="password" name="password" class="form-control" required>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Confirm Password *</label>
                <input type="password" name="confirm_password" class="form-control" required>
            </div>
        </div>
        <button type="submit" class="btn-register"><i class="fas fa-check-circle me-2"></i> Register</button>
    </form>
    <div class="login-link">
        Already have an account? <a href="/login">Login here</a>
    </div>
</div>
</body>
</html>