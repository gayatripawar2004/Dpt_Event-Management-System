<%- include('navbar.ejs') %>
<link rel="stylesheet" href="/css/student/alumni.css">

<!-- Page Header (same as event page) -->
<section class="page-header" style="background-image: url('/images/background image.jpg');">
    <div class="container">
        <h1 class="display-4 fw-bold">Alumni Network</h1>
        <p class="lead fw-bold">Our proud graduates shaping the future of technology</p>
    </div>
</section>

<!-- Alumni Grid -->
<section class="alumni-section py-5" >
    <div class="container">
       <div class="row g-4">
    <% alumniData.forEach(a => { %>
        <div class="col-md-4">
            <div class="alumni-card">
                
                <img src="/uploads/<%= a.image %>" 
                     class="alumni-img" 
                     alt="<%= a.name %>">

                <h4 class="mt-3"><%= a.name %></h4>
                <p class="batch">Batch of <%= a.batch %></p>
                <p class="designation"><%= a.designation %></p>
                <p class="company"><%= a.company %></p>
                <p class="quote">
                    <i class="fas fa-quote-left me-2"></i>
                    <%= a.quote %>
                </p>

            </div>
        </div>
    <% }) %>
</div>
    </div>
</section>

<!-- Join Alumni Network CTA -->
<section class="join-alumni py-5">
    <div class="container">
        <div class="join-card text-center">
            <h2 class="mb-3">Join Our Alumni Network</h2>
            <p class="lead mb-4">Stay connected, mentor current students, and be part of our growing community.</p>
            <button class="btn btn-primary btn-lg" data-bs-toggle="modal" data-bs-target="#joinModal">
                <i class="fas fa-user-plus me-2"></i>Register as Alumni
            </button>
        </div>
    </div>
</section>

<!-- Modal for Alumni Registration -->
<div class="modal fade" id="joinModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Alumni Registration</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
        <form id="alumniForm" action="/alumni/register" method="POST" enctype="multipart/form-data"  onsubmit="return confirmSubmit()">

    <div class="mb-3">
        
        <label class="form-label">Full Name</label>
        <input type="text" name="name" class="form-control" required>
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="form-control" required>
    </div>

    <div class="mb-3">
        <label class="form-label">Passing Year</label>
        <input type="text" name="batch" class="form-control" required>
    </div>

    <div class="mb-3">
        <label class="form-label">Current Designation</label>
        <input type="text" name="designation" class="form-control" required>
    </div>

    <div class="mb-3">
        <label class="form-label">Company</label>
        <input type="text" name="company" class="form-control" required>
    </div>

    <div class="mb-3">
        <label class="form-label">Your Message / Achievement</label>
        <textarea name="quote" class="form-control" rows="3" required></textarea>
    </div>

    <!-- OPTIONAL IMAGE -->
    <div class="mb-3">
        <label class="form-label">Profile Image (Optional)</label>
        <input type="file" name="image" class="form-control">
    </div>

   <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary" >Submit</button>
            </div>

</form>
            </div>
            
        </div>
    </div>
</div>

<%- include('footer.ejs') %>

<script>
    
    
function confirmSubmit() {
    return confirm("Are you sure you want to submit alumni registration?");
}

</script>