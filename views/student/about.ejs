<%- include('navbar.ejs') %>

<!-- Only the about page's own CSS – no event.css -->
<link rel="stylesheet" href="/css/student/about.css">

<!-- Page Header – styled identically to event page -->
<section class="page-header" style="background-image: url('/uploads/<%= header.image %>'); background-size: cover; background-position: center;">
    <div class="container text-white">
        <h1 class="display-4 fw-bold"><%= header.title %></h1>
        <p class="lead fw-bold"><%= header.subtitle %></p>
    </div>
</section>


<!-- Department Overview -->
<section class="py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h2 class="section-title text-start"><%= about.title || 'Department Overview' %></h2>
                <div class="about-description">
                    <%- about.description || '<p>The Department of Electronics and Computer Engineering (E&CE) at Hon. Shri. Babanrao Pachpute Vichardhara Trust\'s Faculty of Engineering, Kashti, was established with a vision to produce industry-ready engineers. Our curriculum blends core electronics with cutting-edge computer science, preparing students for careers in embedded systems, IoT, VLSI, AI/ML, and software development.</p><p>With state-of-the-art laboratories, experienced faculty, and strong industry connections, we foster innovation, research, and holistic development. The department regularly organizes workshops, seminars, hackathons, and technical fests to enhance practical knowledge and employability.</p>' %>
                </div>
                <% if(about.accreditation) { %>
                    <p><strong>Accreditation:</strong> <%= about.accreditation %></p>
                <% } %>
            </div>
            <div class="col-lg-6">
                <% if(about.image && about.image !== 'default-about.jpg') { %>
                    <img src="/uploads/<%= about.image %>" alt="Department Lab" class="img-fluid rounded-4 shadow about-img">
                <% } else { %>
                    <img src="https://images.unsplash.com/photo-1562774053-701939374585?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Department Lab" class="img-fluid rounded-4 shadow about-img">
                <% } %>
            </div>
        </div>
    </div>
</section>

<!-- Vision & Mission -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="vision-card">
                    <h4><i class="fas fa-eye text-warning me-2"></i> Our Vision</h4>
                    <p><%= about.vision || 'To be a center of excellence in Electronics and Computer Engineering, producing skilled professionals who contribute to society through innovation and ethical practices.' %></p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="mission-card">
                    <h4><i class="fas fa-bullseye text-warning me-2"></i> Our Mission</h4>
                    <p><%= about.mission || 'Impart quality education, promote research and development, and nurture industry-ready engineers with strong problem-solving skills.' %></p>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Faculty Introduction (without photos) -->
<!-- Faculty Section -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="text-center">
            <h2 class="section-title">Our Faculty</h2>
            <p class="mb-5">Experienced, dedicated, and research-oriented educators</p>
        </div>
        <div class="row g-4">
            <% if(faculty && faculty.length > 0) { %>
                <% faculty.forEach(f => { %>
                    <div class="col-md-3 col-sm-6">
                        <div class="faculty-card text-center p-3">
                           
                            <h5 class="mb-1"><%= f.name %></h5>
                            <p class="text-muted mb-1"><%= f.designation %></p>
                            <% if(f.qualification) { %>
                                <small class="text-secondary"><%= f.qualification %></small>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center">
                    <p>Faculty information coming soon...</p>
                </div>
            <% } %>
        </div>
    </div>
</section>

<!-- Labs / Facilities Info -->
<!-- Facilities Section -->
<section class="py-5">
    <div class="container">
        <div class="text-center">
            <h2 class="section-title">Our Facilities</h2>
            <p class="mb-5">State-of-the-art infrastructure and labs</p>
        </div>
        <div class="row g-4">
            <% if(facilities && facilities.length > 0) { %>
                <% facilities.forEach(facility => { %>
                    <div class="col-md-4">
                        <div class="facility-card text-center p-4">
                            <i class="<%= facility.icon_class %> fa-2x mb-3" style="color: #ff7e05;"></i>
                            <h5><%= facility.title %></h5>
                            <p><%= facility.description %></p>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center">
                    <p>Facilities information coming soon...</p>
                </div>
            <% } %>
        </div>
    </div>
</section>

<%- include('footer.ejs') %>