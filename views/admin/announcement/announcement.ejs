<%- include('../sidebar') %>

<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>

<div class="admin-content">
    <h2 class="mb-4">
        <%= announcement ? 'Edit Announcement' : 'Add Announcement' %>
    </h2>

    <div class="card p-4 shadow">
        <form action="<%= announcement ? '/admin/announcement/update/' + announcement.id : '/admin/announcement/add' %>" method="POST">

            <!-- Title -->
            <div class="mb-3">
                <label class="form-label">Announcement Title</label>
                <input type="text" name="title" class="form-control"
                       value="<%= announcement ? announcement.title.replace(/<[^>]+>/g, '') : '' %>"
                       required>
            </div>

            <!-- Description (Rich Text) -->
            <div class="mb-3">
                <label class="form-label">Description</label>
                <div id="editor" style="height:150px;">
                    <%= announcement ? announcement.description : '' %>
                </div>
                <input type="hidden" name="description" id="description">
            </div>

            <!-- STATUS (Only in Edit Mode) -->
            <% if(announcement){ %>
            <div class="mb-3">
                <label class="form-label">Status</label>
                <select name="status" class="form-control">
                    <option value="active" <%= announcement.status === 'active' ? 'selected' : '' %>>Active</option>
                    <option value="inactive" <%= announcement.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                </select>
            </div>
            <% } %>

            <button type="submit" class="btn btn-success">
                <%= announcement ? 'Update' : 'Add' %> Announcement
            </button>

            <a href="/admin/announcement_list" class="btn btn-secondary">View List</a>

        </form>
    </div>
</div>

</main>
<%- include('../footer') %>

<script>
    var quill = new Quill('#editor', {
        theme: 'snow',
        placeholder: 'Write announcement...',
        modules: {
            toolbar: [
                ['bold', 'italic', 'underline'],
                [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                ['link']
            ]
        }
    });

    document.querySelector("form").onsubmit = function() {
        document.querySelector("#description").value = quill.root.innerHTML;
    };
</script>