<%- include('../sidebar') %>

<div class="admin-content">
    <h2>Alumni List</h2>

    <table class="table table-bordered">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Image</th>
                <th>Name</th>
                <th>Batch</th>
                <th>Company</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
        <% alumni.forEach(a => { %>
        <tr>
            <td><%= a.id %></td>
            <td><img src="/uploads/<%= a.image %>" alt="<%= a.name %>" width="50"></td>
            <td><%= a.name %></td>
            <td><%= a.batch %></td>
            <td><%= a.company %></td>

            <!-- Status Badge -->
            <td>
                <% if(a.status === 'approved'){ %>
                    <span class="badge bg-success">approved</span>
                <% } else { %>
                    <span class="badge bg-secondary">pending</span>
                <% } %>
            </td>

            <!-- Toggle Button -->
            <td>
            
    <!-- View Button -->
    <a href="/admin/alumni/view/<%= a.id %>" 
       class="btn btn-info btn-sm">
       View
    </a>
                <% if(a.status === 'approved'){ %>
                    <a href="/admin/alumni/status/<%= a.id %>?status=pending"
                       class="btn btn-warning btn-sm">
                       Deactivate
                    </a>
                <% } else { %>
                    <a href="/admin/alumni/status/<%= a.id %>?status=approved"
                       class="btn btn-success btn-sm">
                       Activate
                    </a>
                <% } %>
            </td>
       </tr>
       <% }) %>
       </tbody>
    </table>
</div>

</main>
<%- include('../footer') %>