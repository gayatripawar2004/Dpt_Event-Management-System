<%- include('../sidebar') %>

<style>
    .facility-card {
        background: white;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        transition: all 0.3s;
    }
    .facility-card:hover {
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        transform: translateY(-2px);
    }
    .facility-icon {
        font-size: 32px;
        width: 50px;
        color: #667eea;
    }
    .table-actions {
        white-space: nowrap;
    }
</style>

<div class="container-fluid px-4 mt-3">
    
    <% if (success) { %>
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i> <%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>
    
    <% if (error) { %>
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i> <%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-building me-2"></i> Manage Facilities</h2>
        <a href="/admin/facilities/add" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i> Add New Facility
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th width="5%">#</th>
                            <th width="10%">Icon</th>
                            <th width="25%">Title</th>
                            <th width="40%">Description</th>
                            <th width="10%">Status</th>
                            <th width="10%">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(facilities && facilities.length > 0) { %>
                            <% facilities.forEach((f, index) => { %>
                                <tr>
                                    <td class="align-middle"><%= index + 1 %></td>
                                    <td class="align-middle">
                                        <i class="<%= f.icon_class %> fa-2x" style="color: #667eea;"></i>
                                    </td>
                                    <td class="align-middle">
                                        <strong><%= f.title %></strong>
                                    </td>
                                    <td class="align-middle">
                                        <%= f.description ? f.description.substring(0, 80) : '' %><%= f.description && f.description.length > 80 ? '...' : '' %>
                                    </td>
                                    <td class="align-middle">
                                        <% if(f.status === 'active') { %>
                                            <span class="badge bg-success">Active</span>
                                        <% } else { %>
                                            <span class="badge bg-secondary">Inactive</span>
                                        <% } %>
                                    </td>
                                    <td class="align-middle table-actions">
                                        <a href="/admin/facilities/edit/<%= f.id %>" class="btn btn-sm btn-info">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a href="/admin/facilities/delete/<%= f.id %>" class="btn btn-sm btn-danger" 
                                           onclick="return confirm('Are you sure you want to delete this facility?')">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <i class="fas fa-building fa-3x text-muted mb-3 d-block"></i>
                                    <h5>No Facilities Found</h5>
                                    <p class="text-muted">Click "Add New Facility" to create your first facility.</p>
                                    <a href="/admin/facilities/add" class="btn btn-primary mt-2">
                                        <i class="fas fa-plus me-2"></i> Add Facility
                                    </a>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<%- include('../footer') %>