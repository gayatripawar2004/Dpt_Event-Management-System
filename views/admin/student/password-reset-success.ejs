<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Password Reset Success - Student Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <meta http-equiv="refresh" content="3;url=/login">
</head>
<body class="bg-gray-100">
    <div class="min-h-screen flex items-center justify-center">
        <div class="bg-white p-8 rounded-lg shadow-md w-full max-w-md text-center">
            <div class="mb-6">
                <div class="mx-auto flex items-center justify-center h-16 w-16 bg-green-100 rounded-full">
                    <svg class="h-8 w-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                </div>
            </div>
            
            <h2 class="text-2xl font-bold text-gray-800 mb-4">Password Reset Successful!</h2>
            
            <% if (success) { %>
                <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
                    <%= success %>
                </div>
            <% } %>
            
            <p class="text-gray-600 mb-6">Redirecting you to login page...</p>
            
            <div class="mt-4">
                <a href="/login" class="text-blue-500 hover:text-blue-600">Click here if not redirected</a>
            </div>
        </div>
    </div>
</body>
</html>