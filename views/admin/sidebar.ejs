     <main class="admin-main">
      <div class="admin-topbar">

    <!-- LEFT -->
    <div class="topbar-left d-flex align-items-center">

        <!-- SIDEBAR TOGGLE -->
        <button class="sidebar-toggle-btn me-3" id="sidebarToggleBtn">
            <i class="fas fa-bars"></i>
        </button>

        
      
    </div>

    <!-- RIGHT -->
    <div class="topbar-right d-flex align-items-center">

     

        <!-- NOTIFICATIONS -->
   <!-- NOTIFICATIONS -->
<div class="dropdown me-3">
    <a class="topbar-icon position-relative" href="#" data-bs-toggle="dropdown">
        <i class="fas fa-bell"></i>
        <% if (typeof unreadCount !== 'undefined' && unreadCount) { %>
            <span class="notification-badge"><%= unreadCount %></span>
        <% } else { %>
            <span class="notification-badge">0</span>
        <% } %>
    </a>

    <ul class="dropdown-menu dropdown-menu-end shadow">
        <li class="dropdown-header">Notifications</li>
        <% if (typeof notifications !== 'undefined' && notifications && notifications.length > 0) { %>
            <% notifications.forEach(n => { %>
                <li>
                    <a class="dropdown-item" href="/admin/notifications">
                        <strong><%= n.title %></strong><br>
                        <small><%= n.message %></small>
                    </a>
                </li>
            <% }) %>
        <% } else { %>
            <li><a class="dropdown-item" href="#">No notifications</a></li>
        <% } %>
    </ul>
</div>
        <!-- PROFILE -->
      <div class="dropdown">

    <a class="d-flex align-items-center text-decoration-none dropdown-toggle"
       href="#"
       role="button"
       data-bs-toggle="dropdown"
       aria-expanded="false">

        <% if(admin.profile_image && admin.profile_image !== 'default-avatar.png') { %>

            <img
                src="/uploads/<%= admin.profile_image %>"
                width="40"
                height="40"
                class="rounded-circle border"
            >

        <% } else { %>

            <img
                src="/uploads/img/default-avatar.png"
                width="40"
                height="40"
                class="rounded-circle border"
            >

        <% } %>

        <span class="ms-2 fw-semibold text-dark d-none d-md-inline">
            Admin
        </span>

    </a>

    <ul class="dropdown-menu dropdown-menu-end">
        <li>
            <a class="dropdown-item" href="/admin/profile">
                <i class="fas fa-user me-2"></i> Profile
            </a>
        </li>

        <li><hr class="dropdown-divider"></li>

        <li>
            <a class="dropdown-item text-danger" href="/admin/logout">
                <i class="fas fa-sign-out-alt me-2"></i> Logout
            </a>
        </li>
    </ul>

</div>

    </div>

</div>
    
     
<script>

    // SUBMENU TOGGLE
    document.querySelectorAll('.submenu-toggle').forEach(menu => {

        menu.addEventListener('click', function(e) {

            e.preventDefault();

            let parent = this.parentElement;

            parent.classList.toggle('open');

        });

    });


    // SIDEBAR TOGGLE
    const sidebarBtn = document.getElementById('sidebarToggleBtn');
    const sidebar = document.getElementById('adminSidebar');
    const adminMain = document.querySelector('.admin-main');

    sidebarBtn.addEventListener('click', () => {

        sidebar.classList.toggle('collapsed');
        adminMain.classList.toggle('expanded');

    });

</script>