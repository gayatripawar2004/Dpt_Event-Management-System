<style>
    .admin-content {
        flex: 1;
        padding: 1.8rem;
        background: #f8fafc;
    }

    .card {
        border: none;
        border-radius: 1.25rem;
        overflow: hidden;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05),
                    0 8px 10px -6px rgba(0, 0, 0, 0.02);
    }

    .card-header {
        background: white;
        border-bottom: 2px solid #eef2ff;
        padding: 1.2rem 1.5rem;
        font-weight: 600;
        font-size: 1.1rem;
        color: #1e293b;
    }

    .form-label {
        font-weight: 500;
        color: #0f172a;
        margin-bottom: 0.5rem;
    }

    .form-control {
        border-radius: 0.75rem;
        padding: 0.7rem 1rem;
        border: 1px solid #e2e8f0;
    }

    .btn-success {
        background: #0d6efd;
        border: none;
        padding: 0.5rem 1.8rem;
        border-radius: 2rem;
    }

    .btn-success:hover {
        background: #0b5ed7;
    }
</style>

<%- include('../sidebar') %>

<div class="admin-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">
            <i class="fas fa-address-book me-2 text-primary"></i> Contact Info
        </h1>
    </div>

    <!-- Form Card -->
    <div class="card shadow-sm">
        <div class="card-header">
            <i class="fas fa-pen-alt me-2 text-primary"></i> Edit Contact Information
        </div>

        <div class="card-body">
            <form action="/admin/contact-info/update" method="POST">

                <!-- Address -->
                <div class="mb-4">
                    <label class="form-label">Address</label>
                    <textarea name="address" class="form-control" rows="3" required><%= info?.address || '' %></textarea>
                </div>

                <!-- Emails -->
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label">Email 1</label>
                        <input type="email" name="email1" class="form-control"
                               value="<%= info?.email1 || '' %>" required>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label">Email 2</label>
                        <input type="email" name="email2" class="form-control"
                               value="<%= info?.email2 || '' %>">
                    </div>
                </div>

                <!-- Phones -->
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label">Phone 1</label>
                        <input type="text" name="phone1" class="form-control"
                               value="<%= info?.phone1 || '' %>" required>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label">Phone 2</label>
                        <input type="text" name="phone2" class="form-control"
                               value="<%= info?.phone2 || '' %>">
                    </div>
                </div>

                <!-- Office Hours -->
                <div class="mb-4">
                    <label class="form-label">Weekday Hours</label>
                    <input type="text" name="office_hours_weekdays" class="form-control"
                           value="<%= info?.office_hours_weekdays || '' %>" required>
                </div>

                <div class="mb-4">
                    <label class="form-label">Saturday Hours</label>
                    <input type="text" name="office_hours_saturday" class="form-control"
                           value="<%= info?.office_hours_saturday || '' %>">
                </div>

                <!-- Social Links -->
                <div class="mb-4">
                    <label class="form-label">Facebook Link</label>
                    <input type="text" name="facebook_link" class="form-control"
                           value="<%= info?.facebook_link || '' %>">
                </div>

                <div class="mb-4">
                    <label class="form-label">Instagram Link</label>
                    <input type="text" name="instagram_link" class="form-control"
                           value="<%= info?.instagram_link || '' %>">
                </div>

               

                <div class="mb-4">
                    <label class="form-label">Youtube Link</label>
                    <input type="text" name="youtube_link" class="form-control"
                           value="<%= info?.youtube_link || '' %>">
                </div>

                <!-- Submit -->
                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-success px-5">
                        <i class="fas fa-save me-2"></i> Update
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

</main>
<%- include('../footer') %>