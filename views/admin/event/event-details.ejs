<%- include('../sidebar.ejs') %>
 <style>
        /* Very minimal custom style – just for basic spacing */
        body {
            background: #f8f9fc;
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
        }
        .simple-card {
            background: #fff;
            border: 1px solid #dee2e6;
            border-radius: 0.5rem;
            margin-bottom: 1.5rem;
        }
        .simple-card .card-header {
            background: #fff;
            border-bottom: 1px solid #dee2e6;
            font-weight: 600;
            padding: 0.75rem 1rem;
        }
        .simple-card .card-body {
            padding: 1rem;
        }
        .event-image {
            max-width: 100%;
            height: auto;
            border: 1px solid #ddd;
            border-radius: 0.375rem;
        }
        .badge-status {
            font-size: 0.8rem;
            padding: 0.25rem 0.75rem;
            border-radius: 1rem;
        }
        .list-group-item {
            border: none;
            padding: 0.5rem 0;
            background: transparent;
        }
        hr {
            margin: 1rem 0;
        }
    </style>
<div class="container mt-4">

    <h3 class="mb-3"><%= event.title %></h3>

    <!-- Basic Info -->
    <div class="card mb-3">
        <div class="card-header">Event Info</div>
        <div class="card-body">

            <% if(event.image){ %>
                <img src="/uploads/<%= event.image %>" width="200" class="mb-3">
            <% } %>

            <p><strong>Date:</strong> <%= event.date.toLocaleDateString('en-GB', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></p>
            <p><strong>Time:</strong> <%= event.time %></p>
            <p><strong>Venue:</strong> <%= event.venue %></p>
            <p><strong>Seats:</strong> <%= event.seats %></p>
            <p><strong>Status:</strong> 
                <span class="badge bg-<%= event.status === 'active' ? 'success' : 'secondary' %>">
                    <%= event.status %>
                </span>
            </p>
        </div>
    </div>

    <!-- Description -->
    <div class="card mb-3">
        <div class="card-header">Description</div>
        <div class="card-body">
            <p><%= event.description %></p>
        </div>
    </div>

    <!-- Organizer -->
    <div class="card mb-3">
        <div class="card-header">Organizer Info</div>
        <div class="card-body">
            <p><strong>Name:</strong> <%= event.organizer %></p>
            <p><strong>Email:</strong> <%= event.contactEmail %></p>
            <p><strong>Phone:</strong> <%= event.contactPhone %></p>
        </div>
    </div>

    <!-- Registration Fields -->
   <div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Registration Fields</span>

        <!-- ADD BUTTON -->
       <a href="/admin/event-registrations/<%= event.id %>"  class="btn btn-sm btn-primary">
            View Registered Students
        </a>
    </div>
    </div>
   
    <div class="card mb-3 text-center">
    <div class="card-header">
        Attendance QR Code
    </div>

    <div class="card-body">

        <img 
            src="https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=http://10.198.73.172:3000/mark-attendance?event_id=<%= event.id %>" 
            alt="QR Code"
            class="mb-3"
        >

        <p class="small text-muted mb-3">
            Scan this QR to mark attendance
        </p>

        <!-- View Attendance Button -->
        <a href="/admin/event-attendance/<%= event.id %>" 
           class="btn btn-success btn-sm">
           View Attendance
        </a>

    </div>
</div>

    <div class="card-body">
        <% if(fields.length > 0){ %>
            <ul>
                <% fields.forEach(f => { %>
                    <li>
                        <%= f.field_label %> (<%= f.field_type %>)
                    </li>
                <% }) %>
            </ul>
        <% } else { %>
            <p>No fields added</p>
        <% } %>
    </div>


   

</div>

    <!-- Back Button -->
    <a href="/admin/event_list" class="btn btn-secondary">Back</a>

</div>

<%- include('../footer.ejs') %>