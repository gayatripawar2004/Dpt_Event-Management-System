<%- include('../sidebar') %>

<div class="container-fluid mt-4">

    <style>
        .info-box {
    background: #f8f9fa;
    padding: 12px 15px;
    border-radius: 10px;
    font-size: 14px;
}

.table td, .table th {
    vertical-align: middle;
}

.btn i {
    font-size: 13px;
}
    </style>
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold text-dark">Pending Student Requests</h4>
        <span class="badge bg-warning text-dark fs-6">
            Total: <%= students.length %>
        </span>
    </div>

    <!-- Card -->
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body">

            <div class="table-responsive">
                <table class="table table-hover align-middle">

                    <thead class="table-light">
                        <tr class="text-secondary">
                            <th>#</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>PRN</th>
                            <th>Department</th>
                            <th>Year</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% students.forEach((s, index) => { %>
                            <tr>
                                <td class="fw-semibold"><%= index + 1 %></td>

                                <td>
                                    <div class="fw-semibold text-dark">
                                        <%= s.name %>
                                    </div>
                                </td>

                                <td class="text-muted small">
                                    <%= s.email %>
                                </td>

                                <td><%= s.prn %></td>

                                <td>
                                    <span class="badge bg-info-subtle text-dark">
                                        <%= s.department %>
                                    </span>
                                </td>

                                <td>
                                    <span class="badge bg-secondary-subtle text-dark">
                                        <%= s.year %>
                                    </span>
                                </td>

                                <td class="text-center">
                                    <button class="btn btn-outline-primary btn-sm me-1"
                                        data-bs-toggle="modal"
                                        data-bs-target="#viewModal<%= s.id %>">
                                        <i class="fas fa-eye"></i>
                                    </button>

                                    <a href="/admin/approve-student/<%= s.id %>"
                                       class="btn btn-success btn-sm me-1">
                                       <i class="fas fa-check"></i>
                                    </a>

                                    <a href="/admin/reject-student/<%= s.id %>"
                                       class="btn btn-danger btn-sm">
                                       <i class="fas fa-times"></i>
                                    </a>
                                </td>
                            </tr>

                            <!-- MODAL -->
                            <div class="modal fade" id="viewModal<%= s.id %>" tabindex="-1">
                                <div class="modal-dialog modal-lg modal-dialog-centered">
                                    <div class="modal-content rounded-3">

                                        <div class="modal-header bg-light">
                                            <h5 class="modal-title fw-semibold">
                                                Student Details
                                            </h5>
                                            <button class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>

                                        <div class="modal-body">
                                            <div class="row g-3">

                                                <div class="col-md-6">
                                                    <div class="info-box">
                                                        <p><b>Name:</b> <%= s.name %></p>
                                                        <p><b>Email:</b> <%= s.email %></p>
                                                        <p><b>Mobile:</b> <%= s.mobile %></p>
                                                        <p><b>PRN:</b> <%= s.prn %></p>
                                                    </div>
                                                </div>

                                                <div class="col-md-6">
                                                    <div class="info-box">
                                                        <p><b>Department:</b> <%= s.department %></p>
                                                        <p><b>Year:</b> <%= s.year %></p>
                                                        <p><b>Parent Name:</b> <%= s.parents_name %></p>
                                                        <p><b>Parent Mobile:</b> <%= s.parents_mobile %></p>
                                                    </div>
                                                </div>

                                            </div>
                                        </div>

                                        <div class="modal-footer">
                                            <a href="/admin/approve-student/<%= s.id %>"
                                               class="btn btn-success">
                                               Approve
                                            </a>

                                            <a href="/admin/reject-student/<%= s.id %>"
                                               class="btn btn-danger">
                                               Reject
                                            </a>

                                            <button class="btn btn-secondary"
                                                    data-bs-dismiss="modal">
                                                Close
                                            </button>
                                        </div>

                                    </div>
                                </div>
                            </div>

                        <% }) %>
                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>

</main>
<%- include('../footer') %>